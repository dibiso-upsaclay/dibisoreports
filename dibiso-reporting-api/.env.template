## Docker Configuration
COMPOSE_PROJECT_NAME=dibiso-reporting

## API Configuration
# Admin user credentials (created automatically on first startup if no admin exists)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

ACCESS_TOKEN_EXPIRE_HOURS=48
PROJECTS_PERSISTENCE_TIME_HOURS=4
PROJECTS_ANALYSES_RETENTION_DAYS=30

USERS_DATABASE_NAME=users.db
# Docker: leave as /api_data (mapped to a host volume in docker-compose.yml)
# Dev (Windows): use a local path, e.g. ./api_data
USERS_DATABASE_DIRECTORY=/api_data

# HTML report templates — local path on the Docker host (mounted into the container)
# Leave blank to fall back to GitHub download
HTML_TEMPLATE_PATH=
HTML_TEMPLATE_URL=https://github.com/dibiso-upsaclay/dibiso-html-templates/releases/latest
DEFAULT_MAX_ENTITIES=500

# CORS — space-separated list of allowed origins
# e.g.: http://localhost:3000,https://reporting.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Thread pool for report generation (one report per worker)
THREAD_POOL_MAX_WORKERS=4

# Timeout for the data-fetching subprocess (seconds).
# First run with no cache can take 10-20 min for large labs.
DATA_FETCHING_TIMEOUT_SECONDS=1200

API_TITLE=DiBISOreport generator API
API_VERSION=0.1.0

# Development only (ignored in Docker)
DEV_API_HOST=0.0.0.0
DEV_API_PORT=8000

# Docker deployment — host:port the container port 8000 is mapped to
API_PORT=127.0.0.1:8000

## ScanR API credentials
SCANR_API_PASSWORD=
SCANR_API_URL=
SCANR_API_USERNAME=
SCANR_BSO_INDEX=
SCANR_PUBLICATIONS_INDEX=

## OpenAlex
# Docker: leave as /openalex_analysis_cache (mapped to a host volume)
# Dev (Windows): use the default openalex-analysis path, e.g. C:/Users/<user>/openalex-analysis/data
OPENALEX_ANALYSIS_CACHE_PATH=/openalex_analysis_cache
OPENALEX_API_KEY=
OPENALEX_EMAIL=
