## ── Docker ────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=dibiso-reporting
# Host address:port the API is reachable on (browser → API)
API_PORT=127.0.0.1:8000
# Host address:port the webapp is reachable on
WEBAPP_PORT=127.0.0.1:8080

## ── Webapp ────────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API — must be publicly reachable
# (baked into the webapp at build time via Vite)
VITE_API_URL=http://127.0.0.1:8000

## ── API — Auth ────────────────────────────────────────────────────────────────
# Admin account created automatically on first startup if no admin exists
ADMIN_USERNAME=
ADMIN_PASSWORD=

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

ACCESS_TOKEN_EXPIRE_HOURS=48

## ── API — Storage ─────────────────────────────────────────────────────────────
USERS_DATABASE_NAME=users.db
PROJECTS_PERSISTENCE_TIME_HOURS=4
PROJECTS_ANALYSES_RETENTION_DAYS=30

## ── API — HTML templates ──────────────────────────────────────────────────────
# Local dibiso-html-templates/ directory is bind-mounted into the container.
# This URL is the fallback if the mount is unavailable.
HTML_TEMPLATE_URL=https://github.com/dibiso-upsaclay/dibiso-html-templates/releases/latest
DEFAULT_MAX_ENTITIES=500

## ── API — CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Must include the webapp origin (scheme + host + port).
CORS_ALLOW_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

## ── API — Performance ─────────────────────────────────────────────────────────
# Number of concurrent report-generation workers
THREAD_POOL_MAX_WORKERS=4
# Timeout for the data-fetching step (seconds); first run can take 10-20 min
DATA_FETCHING_TIMEOUT_SECONDS=1200

## ── API — Metadata ────────────────────────────────────────────────────────────
API_TITLE=DiBISOreport generator API
API_VERSION=0.1.0

## ── ScanR ─────────────────────────────────────────────────────────────────────
SCANR_API_PASSWORD=
SCANR_API_URL=
SCANR_API_USERNAME=
SCANR_BSO_INDEX=
SCANR_PUBLICATIONS_INDEX=

## ── OpenAlex ──────────────────────────────────────────────────────────────────
OPENALEX_API_KEY=
OPENALEX_EMAIL=
